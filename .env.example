# Required: Fireworks AI API key (https://fireworks.ai)
FIREWORKS_API_KEY=fw_your_key_here

# Optional overrides (defaults shown)
# SEVCAP_MODEL=accounts/fireworks/models/kimi-k2p6
# SEVCAP_VISION_MODEL=accounts/fireworks/models/kimi-k2p6
# SEVCAP_FALLBACK_VISION_MODEL=accounts/fireworks/models/qwen2p5-vl-32b-instruct
# SEVCAP_FRAMES=6                  # keyframes at 30s (scales to SEVCAP_FRAMES_MAX at 120s)
# SEVCAP_FRAMES_MAX=12
# SEVCAP_CLIP_UPGRADE_TIMEOUT=420   # per-clip Stage-2 cap at 60s (scales up at 120s)
# SEVCAP_CLIP_UPGRADE_TIMEOUT_MAX=540
# SEVCAP_TIME_BUDGET=900          # seconds for the whole run (anytime algorithm)
# SEVCAP_CANDIDATES=2             # styled caption candidates per style (vision-picked)
# SEVCAP_POLISH=1                 # reselect weak styles after first pass
# SEVCAP_POLISH_ROUNDS=1
# SEVCAP_CLIP_CONCURRENCY=2
# SEVCAP_LLM_CONCURRENCY=6
# SEVCAP_AUDIO=0                  # 1 enables local Whisper dialogue transcription
# SEVCAP_WHISPER_MODEL=base       # tiny/base/small (faster-whisper, CPU, int8)
# INPUT_DIR=/input
# OUTPUT_DIR=/output
# INPUT_PATH=/input/tasks.json
# OUTPUT_PATH=/output/results.json
