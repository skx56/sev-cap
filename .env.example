# Required: Fireworks AI API key (https://fireworks.ai)
FIREWORKS_API_KEY=fw_your_key_here

# Optional overrides (defaults shown)
# SEVCAP_MODEL=accounts/fireworks/models/gemma-3-27b-it
# SEVCAP_VISION_MODEL=accounts/fireworks/models/gemma-3-27b-it
# SEVCAP_FALLBACK_VISION_MODEL=accounts/fireworks/models/qwen2p5-vl-32b-instruct
# SEVCAP_K=5                      # independent fact-extraction samples
# SEVCAP_MIN_SUPPORT=3            # keep facts appearing in >= this many of K samples
# SEVCAP_FRAMES=6                  # keyframes at 30s (scales to SEVCAP_FRAMES_MAX at 120s)
# SEVCAP_FRAMES_MAX=12
# SEVCAP_MAX_SCENES_MIN=8           # scene timeline lines at 30s
# SEVCAP_MAX_SCENES_MAX=16          # scene timeline lines at 120s
# SEVCAP_CLIP_UPGRADE_TIMEOUT=420   # per-clip Stage-2 cap at 60s (scales up at 120s)
# SEVCAP_CLIP_UPGRADE_TIMEOUT_MAX=540
# SEVCAP_TIME_BUDGET=1500         # seconds for the whole run (anytime algorithm)
# SEVCAP_MAX_REFINE_ROUNDS=2
# SEVCAP_CLIP_CONCURRENCY=3
# SEVCAP_LLM_CONCURRENCY=8
# SEVCAP_AUDIO=1                  # 0 disables local Whisper dialogue transcription
# SEVCAP_WHISPER_MODEL=base       # tiny/base/small (faster-whisper, CPU, int8)
# INPUT_DIR=/input
# OUTPUT_DIR=/output
